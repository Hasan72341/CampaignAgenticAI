# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=campaignx
POSTGRES_PASSWORD=campaignx_secret
POSTGRES_DB=campaignx_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Ollama LLM ───────────────────────────────────────────────
# Ollama must be running on the host machine.
# Run: ollama run glm4:latest  (or whichever model you prefer)
# host.docker.internal lets the Docker container reach the host Ollama server.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=glm-5:cloud

# ─── Hackathon API ────────────────────────────────────────────
# Register at https://campaignx.inxiteout.ai/api/v1/signup
# The key is shown ONCE — store it immediately.
HACKATHON_TEAM_NAME=your_team_name_here
HACKATHON_TEAM_EMAIL=your_team_email_here
HACKATHON_API_KEY=your_hackathon_api_key_here
HACKATHON_API_BASE_URL=https://campaignx.inxiteout.ai
